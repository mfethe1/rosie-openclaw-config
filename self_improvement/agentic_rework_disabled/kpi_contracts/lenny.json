{
  "lane_owner": "lenny",
  "version": "1.0.0",
  "contract_window": "daily",
  "pass_rule": "at_least_3_of_4_required_kpis_pass_and_forecast_error_within_limit",
  "sunset_rule": {
    "condition": "4 consecutive misses on forecast_error_pct OR pipeline coverage under floor for 7 days",
    "action": "sunset outbound expansion loop and trigger pipeline rebuild sprint"
  },
  "budget_cap_hints": {
    "daily_soft_cap_usd": 220,
    "daily_hard_cap_usd": 360,
    "weekly_soft_cap_usd": 1300
  },
  "kpis": [
    {
      "name": "pipeline_coverage_x",
      "pass_threshold": ">= 3.0",
      "fail_threshold": "< 2.0"
    },
    {
      "name": "stage_progression_pct",
      "pass_threshold": ">= 25",
      "fail_threshold": "< 15"
    },
    {
      "name": "meeting_to_sql_pct",
      "pass_threshold": ">= 35",
      "fail_threshold": "< 22"
    },
    {
      "name": "forecast_error_pct",
      "pass_threshold": "<= 10",
      "fail_threshold": "> 18"
    }
  ]
}
