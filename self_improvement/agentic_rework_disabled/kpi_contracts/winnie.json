{
  "lane_owner": "winnie",
  "version": "1.0.0",
  "contract_window": "daily",
  "pass_rule": "all_compliance_kpis_pass_and_no_critical_findings",
  "sunset_rule": {
    "condition": "any critical compliance failure OR 2 consecutive compliance misses",
    "action": "immediate sunset of affected workflow until compliance sign-off"
  },
  "budget_cap_hints": {
    "daily_soft_cap_usd": 250,
    "daily_hard_cap_usd": 400,
    "weekly_soft_cap_usd": 1500
  },
  "kpis": [
    {
      "name": "compliance_pass_rate_pct",
      "pass_threshold": ">= 99",
      "fail_threshold": "< 97"
    },
    {
      "name": "critical_findings_count",
      "pass_threshold": "== 0",
      "fail_threshold": "> 0"
    },
    {
      "name": "citation_coverage_pct",
      "pass_threshold": ">= 95",
      "fail_threshold": "< 90"
    },
    {
      "name": "sla_on_time_pct",
      "pass_threshold": ">= 97",
      "fail_threshold": "< 93"
    }
  ]
}
