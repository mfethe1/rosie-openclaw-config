{
  "lane_owner": "mack",
  "version": "1.0.0",
  "contract_window": "daily",
  "pass_rule": "at_least_3_of_4_required_kpis_pass",
  "sunset_rule": {
    "condition": "5 consecutive daily failures OR budget hard-cap breach twice in 14 days",
    "action": "sunset experimental automations and revert to last stable workflow"
  },
  "budget_cap_hints": {
    "daily_soft_cap_usd": 300,
    "daily_hard_cap_usd": 500,
    "weekly_soft_cap_usd": 1800
  },
  "kpis": [
    {
      "name": "qualified_leads_count",
      "pass_threshold": ">= 12",
      "fail_threshold": "< 8"
    },
    {
      "name": "ctr_pct",
      "pass_threshold": ">= 3.5",
      "fail_threshold": "< 2.0"
    },
    {
      "name": "cost_per_qualified_lead_usd",
      "pass_threshold": "<= 120",
      "fail_threshold": "> 170"
    },
    {
      "name": "on_time_sync_pct",
      "pass_threshold": ">= 98",
      "fail_threshold": "< 95"
    }
  ]
}
